# Anthropic API-nyckel (obligatorisk) — https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Modell (valfri). Standard: claude-opus-4-8.
# För lägre latens/kostnad: claude-haiku-4-5
GAME_HELPER_MODEL=claude-opus-4-8

# Vilket spel du spelar — injiceras i alla prompts som kontext
GAME_HELPER_SPEL=Red Matter 2
GAME_HELPER_PLATTFORM=PS5 med PSVR2

# Endast för discord_bot.py (valfritt)
# DISCORD_BOT_TOKEN=...
# GAME_HELPER_SERVER=http://localhost:8000
