# Anthropic API-nyckel (obligatorisk) — https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Modell (valfri). Standard: claude-opus-4-8.
# För lägre latens/kostnad: claude-haiku-4-5
GAME_HELPER_MODEL=claude-opus-4-8

# Vilket spel du spelar — injiceras i alla prompts som kontext
GAME_HELPER_SPEL=Red Matter 2
GAME_HELPER_PLATTFORM=PS5 med PSVR2

# Discord-bottar (valfritt) — token från discord.com/developers
# DISCORD_BOT_TOKEN=...
# GAME_HELPER_SERVER=http://localhost:8000

# Endast röstbotten (discord_voice_bot.py)
# GAME_HELPER_VAKNINGSFRAS=hej kompis
# GAME_HELPER_LYSSNA_ALLT=0            # 1 = varje mening är en fråga, ingen fras krävs
# GAME_HELPER_WHISPER=small            # tiny|base|small|medium — taligenkänningsmodell
# GAME_HELPER_TTS_ROST=sv-SE-SofieNeural   # alt. sv-SE-MattiasNeural
